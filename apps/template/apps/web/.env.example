# Copy this file to .env.local and fill in real values.
# Vercel reads its own env vars from the dashboard / `vercel env` CLI.

# === Required for @deessejs/database (Postgres via postgres-js) ===
DATABASE_URL=postgres://user:pass@localhost:5432/deessejs

# === Required for @deessejs/auth (Better Auth 1.6.19) ===
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-at-least-32-characters-of-entropy
# Production override. Dev defaults to http://localhost:3000.
BETTER_AUTH_URL=http://localhost:3000
# Same-origin app URL, inlined in client builds.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cross-subdomain cookie parent (e.g. example.com if app lives at app.example.com).
PARENT_DOMAIN=localhost

# === OAuth providers (Better Auth spec 1.3, 1.4) — optional ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Optional ===
# Override Better Auth's auto-detected base URL when running behind a
# proxy that rewrites the Host header. Same value as BETTER_AUTH_URL
# in most setups.
LOG_LEVEL=info
