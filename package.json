{
  "name": "deessejs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "check:outdated": "tsx scripts/check-outdated.ts"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "tsx": "^4.19.0"
  }
}
